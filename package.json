{
  "name": "protobuf-support",
  "displayName": "Protobuf Support",
  "description": "Protobuf language support with linting, syntax highlighting, and diagnostics",
  "version": "0.0.1",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "proto",
      "aliases": ["Protobuf", "proto"],
      "extensions": [".proto"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icons/proto.svg",
        "dark": "./icons/proto.svg"
      }
    }],
    "grammars": [{
      "language": "proto",
      "scopeName": "source.proto",
      "path": "./syntaxes/proto.tmLanguage.json"
    }],
    "iconThemes": [{
      "id": "proto-icons",
      "label": "Protobuf Icons",
      "path": "./themes/proto-icons.json"
    }]
  }
}
